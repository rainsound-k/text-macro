{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TextMacro",
  "version": "1.0.3",
  "identifier": "com.textmacro.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "picker",
        "title": "TextMacro",
        "width": 540,
        "height": 420,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "center": true,
        "url": "/"
      },
      {
        "label": "settings",
        "title": "TextMacro 설정",
        "width": 720,
        "height": 560,
        "visible": false,
        "resizable": true,
        "center": true,
        "url": "/"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
